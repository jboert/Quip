# EditorConfig is awesome: https://editorconfig.org
# Universal whitespace policy. Read by Xcode, IntelliJ/Android Studio, VS Code,
# Vim, Emacs, etc. — kills the random "tab vs spaces" diffs that show up when
# someone edits a file in an editor that doesn't share the project's settings.

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
trim_trailing_whitespace = true
insert_final_newline = true

# Swift, Rust, Kotlin all use 4-space indent in this repo.
[*.{swift,rs,kt,kts,java}]
indent_size = 4

# Configuration files conventionally use 2-space.
[*.{yml,yaml,json,toml}]
indent_size = 2

# Markdown is sensitive: a line ending in two spaces is a hard line break,
# so don't trim trailing whitespace.
[*.md]
indent_size = 2
trim_trailing_whitespace = false

# Makefiles require literal tabs.
[Makefile]
indent_style = tab

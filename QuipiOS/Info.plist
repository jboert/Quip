<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>Quip</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>1.2.0</string>
	<key>CFBundleVersion</key>
	<string>3</string>
	<!--
		App Transport Security (ATS) Configuration

		NSAllowsArbitraryLoads = true is required because Quip connects to the
		desktop server via plain ws:// WebSocket on the local network (LAN).
		The server's IP address is discovered dynamically (QR code scan or
		Bonjour), so it cannot be whitelisted by domain in advance.

		NSAllowsLocalNetworking = true is the preferred narrower exception and
		covers local network connections on iOS 10+. Both keys are set for
		backward compatibility.

		Cloudflare tunnel connections use wss:// (TLS) and do not require
		either exception. Certificate pinning for tunnel connections is
		enforced in CloudflareCertificatePinningDelegate (WebSocketClient.swift).

		See also: docs/specs/security-audit.md (L2 finding)
	-->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoads</key>
		<true/>
		<key>NSAllowsLocalNetworking</key>
		<true/>
	</dict>
	<key>NSBluetoothAlwaysUsageDescription</key>
	<string>Quip uses Bluetooth to discover and connect to your Mac.</string>
	<key>NSBluetoothPeripheralUsageDescription</key>
	<string>Quip uses Bluetooth to discover and connect to your Mac.</string>
	<key>NSBonjourServices</key>
	<array>
		<string>_quip._tcp.</string>
		<string>_quip._tcp</string>
	</array>
	<key>NSCameraUsageDescription</key>
	<string>Quip uses the camera to scan QR codes for connecting to your Mac.</string>
	<key>NSLocalNetworkUsageDescription</key>
	<string>Quip connects to your Mac over the local network to control Claude Code sessions.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>Quip needs microphone access for push-to-talk voice commands.</string>
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>Quip uses speech recognition to transcribe your voice commands for Claude Code.</string>
	<key>UIBackgroundModes</key>
	<array>
		<string>audio</string>
	</array>
	<key>UILaunchScreen</key>
	<dict>
		<key>UIColorName</key>
		<string></string>
	</dict>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
</dict>
</plist>
